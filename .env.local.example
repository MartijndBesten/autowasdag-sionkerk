# ══════════════════════════════════════════════════════════════
# Autowasdag Sionkerk — Environment Variables
# Kopieer naar .env.local (nooit committen!)
# ══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
# Project-URL → Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://JOUW-PROJECT.supabase.co

# Anon key (publiek, veilig client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — ALLEEN server-side, nooit client-side!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend (e-mail) ───────────────────────────────────────────
# Maak account op resend.com → API Keys
RESEND_API_KEY=re_JOUW_SLEUTEL

# Ontvanger van organisatienotificaties (nieuwe reserveringen, vrijwilligers enz.)
NOTIFY_EMAIL=m.denbesten@live.nl

# Afzender — VERPLICHT voor productie!
#
# ⚠️ Zonder EMAIL_FROM gebruikt het systeem onboarding@resend.dev (Resend testdomein).
# Met het testdomein worden bevestigingsmails ALLEEN bezorgd bij het Resend-accountadres.
# Alle andere ontvangers krijgen geen mail!
#
# Stap 1: Verifieer je domein op resend.com/domains
# Stap 2: Vul hier je geverifieerde afzenderadres in
EMAIL_FROM=Autowasdag <noreply@autowasdagsionkerk.nl>

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://autowasdagsionkerk.nl
