# ══════════════════════════════════════════════════════════════
# Autowasdag Sionkerk — Environment Variables
# Kopieer naar .env.local (nooit committen!)
# ══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
# Project-URL → Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://JOUW-PROJECT.supabase.co

# Anon key (publiek, veilig client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — ALLEEN server-side, nooit client-side!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend (e-mail) ───────────────────────────────────────────
# Maak account op resend.com → API Keys
RESEND_API_KEY=re_JOUW_SLEUTEL

# Afzender (optioneel — standaard: onboarding@resend.dev voor testen)
# EMAIL_FROM=Autowasdag <noreply@autowasdag.sionkerk.nl>

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://autowasdag.sionkerk.nl

# ── Vercel (automatisch ingesteld op Vercel) ──────────────────
# VERCEL_URL= (automatisch)
